# Server Configuration
PORT=3000

# NTA API Configuration
# Get your API key from https://developer.nationaltransport.ie/
NTA_API_KEY=your_nta_api_key_here

# MOCK_MODE can be set to true to test the server without an NTA API key
MOCK_MODE=false

# Polling interval for real-time TripUpdates feed (in seconds)
RT_FETCH_INTERVAL_SEC=30

# Static GTFS data ZIP download URL
STATIC_GTFS_ZIP_URL=https://www.transportforireland.ie/transitData/Data/GTFS_Realtime.zip

# How often to check for a new static GTFS ZIP file (in hours)
STATIC_REFRESH_INTERVAL_HOURS=24

# Rate Limiting (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
